# Application
APP_NAME=Cloud Server
APP_VERSION=2.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=cloud
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Cookie
COOKIE_DOMAIN=
COOKIE_SECURE=False

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# External APIs (optional, leave empty if not needed)
QWEATHER_HOST="https://kp7p43ap5m.re.qweatherapi.com"
QWEATHER_KEY=your-qweather-key
HOLIDAY_API_BASE="http://timor.tech/api/holiday/year"

